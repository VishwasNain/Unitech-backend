# ========================
# Application Configuration
# ========================
NODE_ENV=development
PORT=5000

# ========================
# Database Configuration (Neon)
# ========================
# Get this from your Neon dashboard
DATABASE_URL=postgresql://neondb_owner:npg_2gsTXGwScl8W@ep-dawn-brook-a1fi5x6y-pooler.ap-southeast-1.aws.neon.tech/Unitech%20Computers?sslmode=require&channel_binding=require

# ========================
# JWT Configuration
# ========================
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=7d

# ========================
# CORS Configuration
# ========================
# Comma-separated list of allowed origins
CLIENT_URL=http://localhost:3000

# ========================
# Rate Limiting
# ========================
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX=100           # 100 requests per window per IP

# ========================
# Logging
# ========================
LOG_LEVEL=info  # error, warn, info, http, verbose, debug, silly

# ========================
# Optional: Sentry (Error Tracking)
# ========================
# SENTRY_DSN=your-sentry-dsn

# ========================
# Optional: Email Service (e.g., SendGrid)
# ========================
# SENDGRID_API_KEY=your-sendgrid-api-key
# EMAIL_FROM=noreply@yourdomain.com

# ========================
# Optional: AWS S3 (for file uploads)
# ========================
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=your-aws-region
# AWS_S3_BUCKET=your-s3-bucket-name
